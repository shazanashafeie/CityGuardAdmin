@page
@model CityGuardAdmin.Pages.UsersModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 fw-bold text-dark mb-0">Users</h1>
        <p class="text-muted small mt-1">
            Manage registered CityGuard users
        </p>
    </div>
    <div class="badge rounded-pill px-3 py-2"
         style="background:#EDE9FE;color:#7C3AED;font-size:0.875rem">
        @Model.Users.Count total users
    </div>
</div>

<!-- Messages -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible rounded-3
                    d-flex align-items-center gap-2">
        <i class="bi bi-check-circle"></i>
        @Model.SuccessMessage
        <button type="button" class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible rounded-3
                    d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle"></i>
        @Model.ErrorMessage
        <button type="button" class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search bar -->
<div class="card-custom p-3 mb-4">
    <div class="input-group">
        <span class="input-group-text bg-white border-end-0 rounded-start-3">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text" id="searchInput"
               class="form-control border-start-0 rounded-end-3"
               placeholder="Search by name or email..."
               oninput="filterUsers(this.value)" />
    </div>
</div>

<!-- Filter tabs -->
<div class="d-flex gap-2 mb-4">
    @foreach (var filter in new[] { "all", "active", "banned", "admin" })
    {
        <a href="/Users?filter=@filter"
           class="btn btn-sm rounded-3 @(Model.CurrentFilter == filter ? "btn-purple" : "btn-outline-secondary")">
            @filter.ToUpper()
        </a>
    }
</div>

<!-- Users table -->
<div class="card-custom">
    @if (!Model.Users.Any())
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size:3rem">👥</div>
            <p class="mt-2">No users found</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="usersTable">
                <thead>
                    <tr>
                        <th class="ps-4">User</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Reports</th>
                        <th class="pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr data-name="@user.DisplayName.ToLower()"
                            data-email="@user.Email.ToLower()">
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <!-- Avatar -->
                                    <div class="rounded-circle d-flex align-items-center
                                                        justify-content-center fw-bold"
                                         style="width:38px;height:38px;
                                                        background:#EDE9FE;
                                                        color:#7C3AED;
                                                        font-size:0.875rem;
                                                        flex-shrink:0">
                                        @(user.DisplayName.Length > 0
                                                                        ? user.DisplayName[0].ToString().ToUpper()
                                                                        : "?")
                                                                          </div>
                                                                          <div>
                                                                              <div class="fw-medium text-dark">
                                            @(string.IsNullOrEmpty(user.DisplayName)
                                                                                ? "Unknown" : user.DisplayName)
                                </div>
                                <div class="text-muted"
                                     style="font-size:0.75rem">
                                    @user.Email
                                </div>
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (user.Role == "admin")
                                {
                                    <span class="badge rounded-pill px-3"
                                          style="background:#EDE9FE;color:#7C3AED">
                                        <i class="bi bi-shield-check me-1"></i>
                                        Admin
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill px-3
                                                             bg-light text-secondary">
                                        User
                                    </span>
                                }
                            </td>
                            <td>
                                @if (!user.IsActive)
                                {
                                    <span class="badge rounded-pill badge-rejected">
                                        Banned
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill badge-verified">
                                        Active
                                    </span>
                                }
                        </td>
                        <td class="text-muted" style="font-size:0.8rem">
                            @user.CreatedAt.ToString("d MMM yyyy")
                        </td>
                        <td>
                            <span class="badge bg-light text-secondary rounded-pill px-3">
                                @(Model.ReportCounts.ContainsKey(user.Id)
                                                            ? Model.ReportCounts[user.Id] : 0)
                        </span>
                    </td>
                    <td class="pe-4">
                        <div class="d-flex gap-1">
                            <!-- View details -->
                            <button class="btn btn-sm btn-outline-secondary rounded-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#userModal"
                                    data-id="@user.Id"
                                    data-name="@user.DisplayName"
                                    data-email="@user.Email"
                                    data-role="@user.Role"
                                    data-active="@user.IsActive.ToString().ToLower()"
                                    data-joined="@user.CreatedAt.ToString("d MMM yyyy")"
                                    data-reports="@(Model.ReportCounts.ContainsKey(user.Id) ? Model.ReportCounts[user.Id] : 0)">
                                <i class="bi bi-eye"></i>
                            </button>

                            @if (user.Role != "admin")
                                    {
                                        <!-- Ban / Unban -->
                                        <form method="post"
                                              asp-page-handler="ToggleBan"
                                              class="d-inline">
                                            <input type="hidden"
                                                   name="userId"
                                                   value="@user.Id" />
                                            <input type="hidden"
                                                   name="isActive"
                                                   value="@(!user.IsActive)" />
                                            <button type="submit"
                                                    class="btn btn-sm rounded-3 @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                    title="@(user.IsActive ? "Ban user" : "Unban user")">
                                                <i class="bi bi-@(user.IsActive ? "slash-circle" : "check-circle")"></i>
                                            </button>
                                        </form>

                                        <!-- Promote to admin -->
                                        <form method="post"
                                              asp-page-handler="Promote"
                                              class="d-inline"
                                              onsubmit="return confirm('Promote @user.DisplayName to admin?')">
                                            <input type="hidden"
                                                   name="userId"
                                                   value="@user.Id" />
                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-primary rounded-3"
                                                    title="Promote to admin">
                                                <i class="bi bi-shield-plus"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- User Detail Modal -->
<div class="modal fade" id="userModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">User Details</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <!-- Avatar + name -->
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle d-flex align-items-center
                                justify-content-center fw-bold"
                         id="modalAvatar"
                         style="width:56px;height:56px;
                                background:#EDE9FE;
                                color:#7C3AED;
                                font-size:1.25rem">
                    </div>
                    <div>
                        <div class="fw-bold text-dark" id="modalName"></div>
                        <div class="text-muted small" id="modalEmail"></div>
                    </div>
                </div>

                <!-- Details -->
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:#F9FAFB">
                            <div class="text-muted small mb-1">Role</div>
                            <div class="fw-medium" id="modalRole"></div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:#F9FAFB">
                            <div class="text-muted small mb-1">Status</div>
                            <div class="fw-medium" id="modalActiveStatus"></div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:#F9FAFB">
                            <div class="text-muted small mb-1">
                                Joined
                            </div>
                            <div class="fw-medium" id="modalJoined"></div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:#F9FAFB">
                            <div class="text-muted small mb-1">
                                Reports submitted
                            </div>
                            <div class="fw-medium" id="modalReports"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button"
                        class="btn btn-outline-secondary rounded-3"
                        data-bs-dismiss="modal">
                    Close
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search filter
        function filterUsers(query) {
            const rows = document.querySelectorAll('#usersTable tbody tr');
            rows.forEach(row => {
                const name = row.getAttribute('data-name') || '';
                const email = row.getAttribute('data-email') || '';
                const match = name.includes(query.toLowerCase()) ||
                              email.includes(query.toLowerCase());
                row.style.display = match ? '' : 'none';
            });
        }

        // Populate user modal
        document.getElementById('userModal')
            .addEventListener('show.bs.modal', function (e) {
                const btn = e.relatedTarget;
                const name = btn.getAttribute('data-name') || '?';

                document.getElementById('modalAvatar').textContent =
                    name[0]?.toUpperCase() ?? '?';
                document.getElementById('modalName').textContent = name;
                document.getElementById('modalEmail').textContent =
                    btn.getAttribute('data-email');
                document.getElementById('modalRole').textContent =
                    btn.getAttribute('data-role');
                document.getElementById('modalJoined').textContent =
                    btn.getAttribute('data-joined');
                document.getElementById('modalReports').textContent =
                    btn.getAttribute('data-reports');

                const isActive = btn.getAttribute('data-active') === 'true';
                const statusEl = document.getElementById('modalActiveStatus');
                statusEl.textContent = isActive ? 'Active' : 'Banned';
                statusEl.style.color = isActive ? '#059669' : '#DC2626';
            });
    </script>
}