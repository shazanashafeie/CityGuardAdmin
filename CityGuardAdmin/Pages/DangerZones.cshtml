@page
@model CityGuardAdmin.Pages.DangerZonesModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Danger Zones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h4 fw-bold text-dark mb-0">Danger Zones</h1>
        <p class="text-muted small mt-1">
            Manage unsafe areas displayed on the CityGuard map
        </p>
    </div>
    <button class="btn btn-purple rounded-3"
            data-bs-toggle="modal"
            data-bs-target="#addZoneModal">
        <i class="bi bi-plus-lg me-1"></i> Add Zone
    </button>
</div>

<!-- Messages -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible rounded-3
                d-flex align-items-center gap-2">
        <i class="bi bi-check-circle"></i>
        <span>@Html.Raw(Model.SuccessMessage)</span>
        <button type="button" class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible rounded-3
                d-flex align-items-center gap-2">
        <i class="bi bi-exclamation-triangle"></i>
        @Model.ErrorMessage
        <button type="button" class="btn-close ms-auto"
                data-bs-dismiss="alert"></button>
    </div>
}

<!-- Map + Table layout -->
<div class="row g-4">

    <!-- Map -->
    <div class="col-md-5">
        <div class="card-custom p-0 overflow-hidden"
             style="height:480px">
            <div id="map" style="width:100%;height:100%"></div>
        </div>
        <p class="text-muted small mt-2 text-center">
            <i class="bi bi-info-circle me-1"></i>
            Red = High · Amber = Medium · Blue = Low
        </p>
    </div>

    <!-- Table -->
    <div class="col-md-7">
        <div class="card-custom">
            @if (!Model.DangerZones.Any())
            {
                <div class="text-center py-5 text-muted">
                    <div style="font-size:3rem">⚠️</div>
                    <p class="mt-2">No danger zones yet</p>
                    <button class="btn btn-purple rounded-3 mt-2"
                            data-bs-toggle="modal"
                            data-bs-target="#addZoneModal">
                        Add first zone
                    </button>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Label</th>
                                <th>Severity</th>
                                <th>Radius</th>
                                <th>Status</th>
                                <th class="pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var zone in Model.DangerZones)
                            {
                                <tr class="@(!zone.IsActive ? "opacity-50" : "")">
                                    <td class="ps-4">
                                        <div class="fw-medium">
                                            @zone.Label
                                        </div>
                                    </td>
                                    <td>
                                        <span class="severity-@zone.Severity fw-semibold text-capitalize">
                                            @zone.Severity
                                        </span>
                                    </td>
                                    <td class="text-muted">
                                        @zone.RadiusMeters m
                                    </td>
                                    <td>
                                        @if (zone.IsActive)
                                        {
                                            <span class="badge rounded-pill badge-verified">
                                                Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill badge-rejected">
                                                Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="pe-4">
                                        <div class="d-flex gap-1 align-items-center">

                                            <!-- Edit -->
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-secondary rounded-3"
                                                    title="Edit zone"
                                                    onclick="openEditModal('@zone.Id', '@zone.Label', '@zone.Severity', @zone.RadiusMeters, '@string.Join(",", zone.Reasons)')">
                                                <i class="bi bi-pencil"></i>
                                            </button>

                                            <!-- Recalculate severity -->
                                            <form method="post"
                                                  asp-page-handler="Recalculate"
                                                  class="d-inline">
                                                <input type="hidden"
                                                       name="zoneId"
                                                       value="@zone.Id" />
                                                <input type="hidden"
                                                       name="lat"
                                                       value="@zone.Latitude" />
                                                <input type="hidden"
                                                       name="lng"
                                                       value="@zone.Longitude" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-info rounded-3"
                                                        title="Recalculate severity">
                                                    <i class="bi bi-arrow-clockwise"></i>
                                                </button>
                                            </form>

                                            <!-- Toggle active -->
                                            <form method="post"
                                                  asp-page-handler="Toggle"
                                                  class="d-inline">
                                                <input type="hidden"
                                                       name="zoneId"
                                                       value="@zone.Id" />
                                                <input type="hidden"
                                                       name="isActive"
                                                       value="@(!zone.IsActive)" />
                                                <button type="submit"
                                                        class="btn btn-sm rounded-3 @(zone.IsActive ? "btn-outline-warning" : "btn-outline-success")"
                                                        title="@(zone.IsActive ? "Deactivate" : "Activate")">
                                                    <i class="bi bi-@(zone.IsActive ? "pause" : "play")"></i>
                                                </button>
                                            </form>

                                            <!-- Delete -->
                                            <form method="post"
                                                  asp-page-handler="Delete"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Delete this danger zone?')">
                                                <input type="hidden"
                                                       name="zoneId"
                                                       value="@zone.Id" />
                                                <button type="submit"
                                                        class="btn btn-sm btn-danger rounded-3"
                                                        title="Delete zone">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Add Zone Modal -->
<div class="modal fade" id="addZoneModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Add Danger Zone</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Add">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Zone Label</label>
                        <input type="text" name="label"
                               class="form-control rounded-3"
                               placeholder="e.g. Poor Lighting Area"
                               required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Location Name</label>
                        <div class="input-group">
                            <input type="text" name="locationName"
                                   id="locationSearchInput"
                                   class="form-control rounded-start-3"
                                   placeholder="e.g. USJ 16 Subang Jaya, Jalan Gombak"
                                   required />
                            <button type="button"
                                    class="btn btn-outline-secondary rounded-end-3"
                                    onclick="searchLocation()">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                        <div class="form-text">
                            Enter the street name, area, or landmark
                            then click search. Coordinates will be found automatically.
                        </div>
                        <div id="locationResult"
                             class="alert alert-success rounded-3 py-2 mt-2 small d-none">
                            <i class="bi bi-geo-alt me-1"></i>
                            <span id="locationResultText"></span>
                        </div>
                        <div id="locationError"
                             class="alert alert-danger rounded-3 py-2 mt-2 small d-none">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            Location not found. Please try a more specific name.
                        </div>
                        <input type="hidden" id="resolvedLat" name="resolvedLat" />
                        <input type="hidden" id="resolvedLng" name="resolvedLng" />
                        <input type="hidden" id="resolvedAddress" name="resolvedAddress" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Radius (meters)</label>
                        <input type="number" name="radiusMeters"
                               class="form-control rounded-3"
                               value="100" min="50" max="1000" required />
                        <div class="form-text">
                            50m = small alley · 200m = city block · 500m = neighbourhood
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Severity Level</label>
                        <select name="severity" id="severitySelect"
                                class="form-select rounded-3" required>
                            <option value="low">🔵 Low — Area feels safe, minor concern</option>
                            <option value="medium" selected>🟠 Medium — Some incidents reported</option>
                            <option value="high">🔴 High — Multiple recent incidents</option>
                        </select>
                        <div id="severitySuggestion"
                             class="alert alert-info rounded-3 py-2 mt-2 small d-none">
                            <i class="bi bi-lightbulb me-1"></i>
                            <strong>System suggestion: </strong>
                            <span id="suggestionText"></span>
                            <br />
                            <span class="text-muted">
                                Based on verified reports and safety ratings near this location.
                            </span>
                        </div>
                        <div class="form-text">
                            💡 Search a location first to get an automatic severity suggestion.
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Reasons (tick all that apply)</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var reason in new[]
                            {
                                "poor lighting", "isolated path",
                                "harassment", "crime", "no cctv",
                                "unsafe path", "frequent incidents"
                            })
                            {
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="reasons"
                                           value="@reason"
                                           id="reason_@reason.Replace(" ", "_")" />
                                    <label class="form-check-label small"
                                           for="reason_@reason.Replace(" ", "_")">
                                        @reason
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button"
                            class="btn btn-outline-secondary rounded-3"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-purple rounded-3">
                        <i class="bi bi-plus-lg me-1"></i> Add Zone
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Zone Modal -->
<div class="modal fade" id="editZoneModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Edit Danger Zone</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-page-handler="Edit">
                <div class="modal-body">
                    <input type="hidden" id="editZoneId" name="zoneId" />

                    <!-- Label -->
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Zone Label</label>
                        <input type="text" id="editLabel" name="label"
                               class="form-control rounded-3" required />
                    </div>

                    <!-- Severity -->
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Severity Level</label>
                        <select id="editSeverity" name="severity"
                                class="form-select rounded-3" required>
                            <option value="low">🔵 Low — Area feels safe, minor concern</option>
                            <option value="medium">🟠 Medium — Some incidents reported</option>
                            <option value="high">🔴 High — Multiple recent incidents</option>
                        </select>
                    </div>

                    <!-- Radius -->
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Radius (meters)</label>
                        <input type="number" id="editRadius" name="radiusMeters"
                               class="form-control rounded-3"
                               min="50" max="1000" required />
                        <div class="form-text">
                            50m = small alley · 200m = city block · 500m = neighbourhood
                        </div>
                    </div>

                    <!-- Reasons -->
                    <div class="mb-3">
                        <label class="form-label fw-medium small">Reasons (tick all that apply)</label>
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var reason in new[]
                            {
                                "poor lighting", "isolated path",
                                "harassment", "crime", "no cctv",
                                "unsafe path", "frequent incidents"
                            })
                            {
                                <div class="form-check">
                                    <input class="form-check-input edit-reason"
                                           type="checkbox"
                                           name="reasons"
                                           value="@reason"
                                           id="edit_reason_@reason.Replace(" ", "_")" />
                                    <label class="form-check-label small"
                                           for="edit_reason_@reason.Replace(" ", "_")">
                                        @reason
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button"
                            class="btn btn-outline-secondary rounded-3"
                            data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-purple rounded-3">
                        <i class="bi bi-check-lg me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Open Edit Modal ──
        function openEditModal(id, label, severity, radius, reasons) {
            document.getElementById('editZoneId').value = id;
            document.getElementById('editLabel').value = label;
            document.getElementById('editSeverity').value = severity;
            document.getElementById('editRadius').value = radius;

            // Uncheck all first
            document.querySelectorAll('.edit-reason').forEach(cb => cb.checked = false);

            // Check matching reasons
            if (reasons) {
                const reasonList = reasons.split(',');
                reasonList.forEach(r => {
                    const cb = document.querySelector(
                        `.edit-reason[value="${r.trim()}"]`);
                    if (cb) cb.checked = true;
                });
            }

            new bootstrap.Modal(
                document.getElementById('editZoneModal')).show();
        }

        // ── Search location and get severity suggestion ──
        async function searchLocation() {
            const input = document.getElementById(
                'locationSearchInput').value.trim();
            if (!input) return;

            const resultDiv = document.getElementById('locationResult');
            const errorDiv = document.getElementById('locationError');
            const resultText = document.getElementById('locationResultText');
            const suggestionDiv = document.getElementById('severitySuggestion');

            resultDiv.classList.add('d-none');
            errorDiv.classList.add('d-none');
            suggestionDiv.classList.add('d-none');

            try {
                const apiKey = 'AIzaSyDrKStt5JDq3mrf8BewV6SDBH_ygxnSqwY';
                const query = encodeURIComponent(input + ', Malaysia');
                const url =
                    `https://maps.googleapis.com/maps/api/geocode/json` +
                    `?address=${query}&key=${apiKey}`;

                const response = await fetch(url);
                const data = await response.json();

                if (data.status === 'OK' && data.results.length > 0) {
                    const loc = data.results[0].geometry.location;
                    const address = data.results[0].formatted_address;

                    document.getElementById('resolvedLat').value = loc.lat;
                    document.getElementById('resolvedLng').value = loc.lng;
                    document.getElementById('resolvedAddress').value = address;

                    resultText.textContent = `Found: ${address}`;
                    resultDiv.classList.remove('d-none');

                    await getSeveritySuggestion(loc.lat, loc.lng);
                } else {
                    errorDiv.classList.remove('d-none');
                    document.getElementById('resolvedLat').value = '';
                    document.getElementById('resolvedLng').value = '';
                }
            } catch (e) {
                errorDiv.classList.remove('d-none');
                console.error('Geocode error:', e);
            }
        }

        // ── Get severity suggestion from server ──
        async function getSeveritySuggestion(lat, lng) {
            const suggestionDiv = document.getElementById('severitySuggestion');
            const suggestionText = document.getElementById('suggestionText');
            const severitySelect = document.getElementById('severitySelect');

            try {
                const response = await fetch(
                    `/DangerZones?handler=SuggestSeverity&lat=${lat}&lng=${lng}`,
                    { headers: { 'X-Requested-With': 'XMLHttpRequest' } }
                );

                if (response.ok) {
                    const result = await response.json();
                    severitySelect.value = result.severity;

                    const colors = { high: 'danger', medium: 'warning', low: 'info' };
                    suggestionDiv.className =
                        `alert alert-${colors[result.severity]} rounded-3 py-2 mt-2 small`;
                    suggestionText.textContent = result.reason;
                    suggestionDiv.classList.remove('d-none');
                }
            } catch (e) {
                console.log('Could not get suggestion:', e);
            }
        }

        // ── Trigger search on Enter key ──
        document.getElementById('locationSearchInput')
            .addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    searchLocation();
                }
            });

        // ── Google Maps init ──
        function initMap() {
            const map = new google.maps.Map(
                document.getElementById('map'), {
                center: { lat: 3.1390, lng: 101.6869 },
                zoom: 13,
                mapTypeId: 'hybrid',
                disableDefaultUI: true,
                zoomControl: true,
            });

            const zones = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.DangerZones.Select(z => new {
                        lat = z.Latitude,
                        lng = z.Longitude,
                        radius = z.RadiusMeters,
                        severity = z.Severity,
                        label = z.Label,
                        isActive = z.IsActive
                    })
                )
            );

            const colors = {
                high: '#E24B4A',
                medium: '#EF9F27',
                low: '#378ADD'
            };

            zones.forEach(zone => {
                if (!zone.isActive) return;

                const color = colors[zone.severity] || '#378ADD';

                const circle = new google.maps.Circle({
                    map,
                    center: { lat: zone.lat, lng: zone.lng },
                    radius: zone.radius,
                    fillColor: color,
                    fillOpacity: 0.25,
                    strokeColor: color,
                    strokeOpacity: 0.8,
                    strokeWeight: 2,
                });

                const infoWindow = new google.maps.InfoWindow({
                    content: `
                        <div style="padding:8px">
                            <strong>${zone.label}</strong><br>
                            <span style="color:${color}">
                                ${zone.severity.toUpperCase()} RISK
                            </span><br>
                            <small>Radius: ${zone.radius}m</small>
                        </div>
                    `
                });

                circle.addListener('click', () => {
                    infoWindow.setPosition({ lat: zone.lat, lng: zone.lng });
                    infoWindow.open(map);
                });

                if (zones.length > 0) {
                    map.setCenter({ lat: zones[0].lat, lng: zones[0].lng });
                }
            });
        }
    </script>

    <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDrKStt5JDq3mrf8BewV6SDBH_ygxnSqwY&callback=initMap"
            async defer></script>
}